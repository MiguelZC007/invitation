{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "project-orchestrator",
  "agent": {
    "project-orchestrator": {
      "description": "Project orchestrator for invitation repository",
      "mode": "primary",
      "model": "openai/gpt-5.3-codex",
      "prompt": "{file:../AGENTS.md}",
      "permission": {
        "task": {
          "*": "deny",
          "code-reviewer": "allow",
          "design-verifier": "allow",
          "git-ops": "allow",
          "hexagonal-guardian": "allow",
          "svg-designer": "allow",
          "test-writer": "allow",
          "ui-designer": "allow",
          "sdd-*-openai": "allow"
        }
      }
    }
  }
}
